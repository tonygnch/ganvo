APP_NAME=Ganvo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://ganvo.lvh.me:8000
CENTRAL_DOMAIN=ganvo.lvh.me

# Coming-soon mode. When true, the marketing homepage at / renders a
# "Launching soon" splash instead of the normal landing page. Onboarding,
# admin panels, and tenant storefronts keep working so the platform owner
# can still operate while the public sees the splash.
COMING_SOON_ENABLED=false
# Optional. Append ?preview=<TOKEN> to / to bypass coming-soon mode without
# logging in. Leave blank to disable preview bypass.
COMING_SOON_BYPASS_TOKEN=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — SQLite by default (single file in database/database.sqlite).
# No host setup needed, ships with the repo.
DB_CONNECTION=sqlite

# To switch to MySQL:
#   1. Comment out DB_CONNECTION=sqlite above.
#   2. Uncomment the block below (the values match the docker-compose
#      `mysql` profile so `docker compose --profile mysql up -d` Just Works).
#   3. Rebuild fresh (or copy your data over with mysqldump):
#         docker exec ganvo php artisan migrate:fresh --seed
#
# DB_CONNECTION=mysql
# DB_HOST=ganvo-mysql      # or 127.0.0.1 if MySQL runs on the host
# DB_PORT=3306
# DB_DATABASE=ganvo
# DB_USERNAME=ganvo
# DB_PASSWORD=ganvo

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Stripe platform billing (Laravel Cashier). The publishable key is exposed
# to Stripe.js in the browser; the secret key is server-side only. Webhook
# secret comes from Stripe Dashboard → Webhooks endpoint after registering
# the /stripe/webhook URL.
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# SEPARATE webhook secret for Stripe Connect events (storefront
# PaymentIntents, account.updated). Stripe issues one per webhook
# endpoint — see Dashboard → Developers → Webhooks → /webhooks/stripe/connect.
STRIPE_CONNECT_WEBHOOK_SECRET=
CASHIER_CURRENCY=eur
