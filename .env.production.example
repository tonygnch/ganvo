# Production .env for ganvo.bg.
# Copy to .env on the server, fill in the placeholders, never commit the
# real file. APP_KEY is generated once by `php artisan key:generate`.

APP_NAME=Ganvo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ganvo.bg
APP_TIMEZONE=Europe/Sofia
CENTRAL_DOMAIN=ganvo.bg

# Force HTTPS for url() / asset() / route() generation. Caddy handles
# the actual TLS; this ensures internal URL generation matches.
APP_FORCE_HTTPS=true

# ---- Coming-soon gate ----------------------------------------------------
# At launch we serve the splash from / and keep admin reachable. Flip to
# false when you're ready to expose the full marketing home.
# The bypass_token lets you preview the real homepage via ?preview=<token>.
COMING_SOON_ENABLED=true
COMING_SOON_BYPASS_TOKEN=                # generate with: php -r "echo bin2hex(random_bytes(16));"

# ---- Locale --------------------------------------------------------------
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ---- Maintenance / cache -------------------------------------------------
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                        # tighten from debug; keep error+ in prod

# ---- Database (MySQL) ----------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ganvo
DB_USERNAME=ganvo
DB_PASSWORD=                             # set during deploy; matches the GRANT below

# ---- Cache / Sessions ----------------------------------------------------
# File-based for simplicity; switch to redis when traffic justifies it.
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true               # HTTPS-only cookies
SESSION_DOMAIN=.ganvo.bg                 # share session across subdomains for tenant storefronts
SESSION_SAME_SITE=lax
QUEUE_CONNECTION=sync                    # no workers yet — sync is fine until we add jobs

# ---- Mail ----------------------------------------------------------------
# 'log' writes mails to storage/logs/laravel.log — no real delivery.
# Swap to smtp + your provider when notifications go live.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@ganvo.bg"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Stripe (platform billing) -------------------------------------------
# Use test keys until you've verified the billing flow end-to-end, then
# swap to live. The webhook secret comes from Stripe Dashboard after
# registering https://ganvo.bg/stripe/webhook.
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=eur

# ---- Filesystem ----------------------------------------------------------
FILESYSTEM_DISK=local

# ---- Vite (build-time only; no effect at runtime in prod) ----------------
VITE_APP_NAME="${APP_NAME}"
